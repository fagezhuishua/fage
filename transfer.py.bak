#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
文件类型转换工具 - Modern GUI Edition (customtkinter + tkinterdnd2)
功能：
1. 支持多种文件格式互转：文档、表格、演示、图像、音频等
2. 现代化 GUI 界面，支持深色/浅色主题
3. 支持拖拽上传文件/文件夹，递归扫描
4. 支持批量转换，结果可下载
5. 详细的错误诊断与格式支持说明
"""

import os
