# ==================== 错误类型定义 ====================
class ConversionError(Exception):
    TYPE_UNSUPPORTED = "不支持的格式"
    TYPE_MISSING_DEP = "缺少依赖"
    TYPE_FILE_NOT_FOUND = "文件不存在"
    TYPE_EMPTY_FILE = "文件为空"
    TYPE_CORRUPTED = "文件损坏"
    TYPE_PERMISSION = "权限不足"
    TYPE_FAILED = "转换失败"

    def __init__(self, err_type: str, detail: str):
        super().__init__(f"[{err_type}] {detail}")
        self.err_type = err_type
        self.detail = detail


